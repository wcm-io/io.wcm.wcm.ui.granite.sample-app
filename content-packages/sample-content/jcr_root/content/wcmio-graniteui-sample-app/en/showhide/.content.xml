                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wcmio-graniteui-sample-app/core/components/ui.granite/showhide-checkbox"/>
                <showhide_select
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wcmio-graniteui-sample-app/core/components/ui.granite/showhide-select"/>
                <showhide_select_multiple
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wcmio-graniteui-sample-app/core/components/ui.granite/showhide-select-multiple"/>
