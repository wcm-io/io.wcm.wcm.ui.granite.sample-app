{
  "jcr:primaryType": "cq:Component",
  "jcr:title": "wcm.io Components All",
  "componentGroup": "wcmio-graniteui-sample-app Granite UI",
  "sling:resourceSuperType": "wcmio-graniteui-sample-app/core/components/global/component",

  "cq:editConfig": {
    "jcr:primaryType": "cq:EditConfig"
  },

  "cq:dialog": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "cq/gui/components/authoring/dialog",
    "jcr:title": "wcm.io Components All",
    "content": {
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "column": {
          "sling:resourceType": "granite/ui/components/coral/foundation/container",
          "items": {
            
            "intro": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "items": {
                "text": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/text",
                  "text": "Test Case: All wcm.io Granite UI components in default configuration"
                }
              }
            },

            "mycheckbox": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mycheckbox",
              "fieldDescription": "Description for checkbox",
              "text": "Check this"
            },

            "mynumber": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/numberfield",
              "name": "./mynumber",
              "fieldLabel": "Number"
            },

            "mydate": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/datepicker",
              "displayedFormat": "DD.MM.YYYY HH:mm",
              "name": "./mydate",
              "type": "datetime",
              "fieldLabel": "Date"
            },

            "mypath": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/pathfield",
              "name": "./mypath",
              "rootPath": "/content",
              "fieldLabel": "Content Path"
            },

            "mydampath": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/pathfield",
              "name": "./mydampath",
              "rootPath": "/content/dam",
              "fieldLabel": "DAM Path"
            }

          }
        }
      }
    }
  }

}
