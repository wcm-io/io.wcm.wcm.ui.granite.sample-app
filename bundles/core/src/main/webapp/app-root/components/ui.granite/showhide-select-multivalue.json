{
  "jcr:primaryType": "cq:Component",
  "jcr:title": "Show/Hide Select (Multiple Values)",
  "componentGroup": "wcmio-graniteui-sample-app Granite UI",
  "sling:resourceSuperType": "wcmio-graniteui-sample-app/core/components/global/component",

  "cq:editConfig": {
    "jcr:primaryType": "cq:EditConfig"
  },

  "cq:dialog": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "cq/gui/components/authoring/dialog",
    "jcr:title": "Show/Hide Select (Multiple Values)",
    "content": {
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "column": {
          "sling:resourceType": "granite/ui/components/coral/foundation/container",
          "items": {

            "intro": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "items": {
                "text": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/text",
                  "text": "Test Case: Select options showing/hiding components"
                }
              }
            },

            "myselect": {
              "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
              "name": "./myselect",
              "fieldLabel": "Example Select",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".myselect-target"
              },
              "items": {
                "option1": {
                  "value": "option1",
                  "text": "Option 1",
                  "selected": true
                },
                "option2": {
                  "value": "option2",
                  "text": "Option 2"
                },
                "option3": {
                  "value": "option3",
                  "text": "Option 3"
                },
                "option4": {
                  "value": "option4",
                  "text": "Option 4"
                },
                "option5": {
                  "value": "option5",
                  "text": "Option 5"
                },
                "option7": {
                  "value": "option6",
                  "text": "Option 6"
                }
              }
            },

            "well1": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "granite:class": "myselect-target",
              "granite:data": {
                "showhidetargetvalues": "option1,option2"
              },
              "items": {
                "mytextfield1a": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                  "name": "./mytextfield1a",
                  "required": true,
                  "fieldLabel": "Example textfield 1a",
                  "fieldDescription": "Visible for Option 1, 2."
                },
                "mytextfield1b": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                  "name": "./mytextfield1b",
                  "fieldLabel": "Example textfield 1b",
                  "fieldDescription": "Visible for Option 1, 2."
                }
              }
            },

            "well2": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "granite:class": "myselect-target",
              "granite:data": {
                "showhidetargetvalues": "option3,option4,option5"
              },
              "items": {
                "mytextfield2": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                  "name": "./mytextfield2",
                  "required": true,
                  "fieldLabel": "Example textfield 2",
                  "fieldDescription": "Visible for Option 3, 4, 5."
                }
              }
            },

            "well3": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "granite:class": "myselect-target",
              "granite:data": {
                "showhidetargetvalue": "option6"
              },
              "items": {
                "mytextfield3": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                  "name": "./mytextfield3",
                  "required": true,
                  "fieldLabel": "Example textfield 3",
                  "fieldDescription": "Visible for Option 6."
                },
                "mycheckbox": {
                  "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
                  "granite:class": "mycheckbox-toggle",
                  "granite:data": {
                    "showhidetargetvalue": "true"
                  },
                  "name": "./mycheckbox3",
                  "text": "Checkbox 3",
                  "fieldDescription": "Visible for Option 6."
                }
              }
            }
          }
        }
      }
    }
  }

}
