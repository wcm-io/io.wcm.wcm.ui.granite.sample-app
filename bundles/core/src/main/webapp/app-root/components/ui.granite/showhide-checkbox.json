{
  "jcr:primaryType": "cq:Component",
  "jcr:title": "Show/Hide Checkbox",
  "componentGroup": "wcmio-graniteui-sample-app Granite UI",
  "sling:resourceSuperType": "wcmio-graniteui-sample-app/core/components/global/component",

  "cq:editConfig": {
    "jcr:primaryType": "cq:EditConfig"
  },

  "cq:dialog": {
    "jcr:primaryType": "nt:unstructured",
    "sling:resourceType": "cq/gui/components/authoring/dialog",
    "jcr:title": "Show/Hide Checkbox",
    "content": {
      "sling:resourceType": "granite/ui/components/coral/foundation/fixedcolumns",
      "items": {
        "column": {
          "sling:resourceType": "granite/ui/components/coral/foundation/container",
          "items": {
            
            "intro": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "items": {
                "text": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/text",
                  "text": "Test Case: Checkboxes showing/hiding different types of target components"
                }
              }
            },

            "mytextfieldToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mytextfieldToggle",
              "text": "Show/Hide Textfield",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mytextfield-toggle"
              }
            },
            "mytextfield": {
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
              "granite:class": "mytextfield-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "name": "./mytextfield",
              "required": true,
              "fieldLabel": "Textfield",
              "fieldDescription": "This is only visible when the checkbox is checked."
            },

            "mytextareaToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mytextareaToggle",
              "text": "Show/Hide Text Area",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mytextarea-toggle"
              }
            },
            "mytextarea": {
              "sling:resourceType": "granite/ui/components/coral/foundation/form/textarea",
              "granite:class": "mytextarea-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "name": "./mytextarea",
              "required": true,
              "fieldLabel": "Text Area",
              "fieldDescription": "This is only visible when the checkbox is checked."
            },

            "mytextToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mytextToggle",
              "text": "Show/Hide Text",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mytext-toggle"
              }
            },
            "mytext": {
              "sling:resourceType": "granite/ui/components/coral/foundation/text",
              "granite:class": "mytext-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "text": "This is only visible when the checkbox is checked."
            },

            "mycheckboxToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mycheckboxToggle",
              "text": "Show/Hide Checkbox",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mycheckbox-toggle"
              }
            },
            "mycheckbox": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "granite:class": "mycheckbox-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "name": "./mycheckbox",
              "text": "Checkbox",
              "fieldDescription": "This is only visible when the checkbox is checked."
            },

            "mypathfieldToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mypathfieldToggle",
              "text": "Show/Hide Pathfield",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mypathfield-toggle"
              }
            },
            "mypathfield": {
              "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
              "granite:class": "mypathfield-toggle",
              "granite:data": {
                "showhidetargetvalue": "true",
                "wcmio-pattern": "^/content/",
                "wcmio-patternmessage": "Path has to start with /content/."
              },
              "name": "./mypathfield",
              "required": true,
              "fieldLabel": "Pathfield (with validation)",
              "fieldDescription": "This is only visible when the checkbox is checked.",
              "validation": ["wcmio.pattern"]
            },

            "myfileuploadToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./myfileuploadToggle",
              "text": "Show/Hide Fileupload",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".myfileupload-toggle"
              }
            },
            "myfileupload": {
              "sling:resourceType": "cq/gui/components/authoring/dialog/fileupload",
              "granite:class": "myfileupload-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "name": "./myfileupload",
              "fileNameParameter": "./myfileuploadFileName",
              "required": true,
              "fieldLabel": "Fileupload (with validation)",
              "fieldDescription": "This is only visible when the checkbox is checked."
            },

            "mynestedselectToggle": {
              "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
              "name": "./mynestedselectToggle",
              "text": "Show/Hide Nested Select",
              "granite:class": "wcmio-dialog-showhide",
              "granite:data": {
                "wcmio-dialog-showhide-target": ".mynestedselect-toggle"
              }
            },
            "nestedselect": {
              "sling:resourceType": "granite/ui/components/coral/foundation/well",
              "granite:class": "mynestedselect-toggle",
              "granite:data": {
                "showhidetargetvalue": "true"
              },
              "items": {
                "nestedcontainer": {
                  "sling:resourceType": "granite/ui/components/coral/foundation/container",
                  "granite:class": "nested-select-parent",
                  "items": {
                    "mysubselect": {
                      "sling:resourceType": "granite/ui/components/coral/foundation/form/select",
                      "name": "./mysubselect",
                      "fieldLabel": "Example Nested Select",
                      "granite:class": "wcmio-dialog-showhide",
                      "granite:data": {
                        "wcmio-dialog-showhide-target": ".mysubselect-target",
                        "wcmio-dialog-showhide-parent": ".nested-select-parent"
                      },
                      "items": {
                        "suboption1": {
                          "value": "suboption1",
                          "text": "Sub Option 1",
                          "selected": true
                        },
                        "suboption2": {
                          "value": "suboption2",
                          "text": "Sub Option 2"
                        },
                        "suboption3": {
                          "value": "suboption3",
                          "text": "Sub Option 3"
                        }
                      }
                    },
                    "subwell1": {
                      "sling:resourceType": "granite/ui/components/coral/foundation/well",
                      "granite:class": "mysubselect-target",
                      "granite:data": {
                        "showhidetargetvalue": "suboption1"
                      },
                      "items": {
                        "mysubtextfield1a": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                          "name": "./mysubtextfield1a",
                          "required": true,
                          "fieldLabel": "Sub Example textfield 1a",
                          "fieldDescription": "Visible for Option 1."
                        },
                        "mysubtextfield1b": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                          "name": "./mysubtextfield1b",
                          "fieldLabel": "Sub Example textfield 1b",
                          "fieldDescription": "Visible for Option 1."
                        },
                        "mysubhiddenfield": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/hidden",
                          "ignoreData": true,
                          "name": "./myhiddenfield",
                          "value": "option1"
                        }
                      }
                    },
                    "subwell2": {
                      "sling:resourceType": "granite/ui/components/coral/foundation/well",
                      "granite:class": "mysubselect-target",
                      "granite:data": {
                        "showhidetargetvalue": "suboption2"
                      },
                      "items": {
                        "mysubpathfield": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/pathfield",
                          "name": "./mysubpathfield",
                          "required": true,
                          "fieldLabel": "Sub Example path field",
                          "fieldDescription": "Visible for Option 2."
                        },
                        "mysubhiddenfield": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/hidden",
                          "ignoreData": true,
                          "name": "./mysubhiddenfield",
                          "value": "option2"
                        }
                      }
                    },
                    "subwell3": {
                      "sling:resourceType": "granite/ui/components/coral/foundation/well",
                      "granite:class": "mysubselect-target",
                      "granite:data": {
                        "showhidetargetvalue": "suboption3"
                      },
                      "items": {
                        "mysubtextfield3": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/textfield",
                          "name": "./mysubtextfield3",
                          "required": true,
                          "fieldLabel": "Sub Example textfield 3",
                          "fieldDescription": "Visible for Option 3."
                        },
                        "mysubcheckbox": {
                          "sling:resourceType": "wcm-io/wcm/ui/granite/components/form/checkbox",
                          "name": "./mysubcheckbox3",
                          "text": "Sub Checkbox 3",
                          "fieldDescription": "Visible for Option 3."
                        },
                        "mysubhiddenfield": {
                          "sling:resourceType": "granite/ui/components/coral/foundation/form/hidden",
                          "ignoreData": true,
                          "name": "./mysubhiddenfield",
                          "value": "option3"
                        }
                      }
                    }
                  }
                }
              }
            }

          }
        }
      }
    }
  }

}
